          "default": null
        },
        "afrr_activation_ratio_down": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "afrr_activation_ratio_up": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "afrr_capacity_down": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "afrr_capacity_up": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "day_ahead": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fcr_capacity": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "imbalance": {
          "anyOf": [
            {
              "$ref": "#/$defs/MarketSeriesInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "RevisionRealizedInputsConfig",
      "type": "object"
    },
    "RiskConfig": {
      "properties": {
        "mode": {
          "default": "expected_value",
          "enum": [
            "expected_value",
            "downside_penalty",
            "cvar_lite"
          ],
          "title": "Mode",
          "type": "string"
        },
        "penalty_lambda": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Penalty Lambda",
          "type": "number"
        },
        "tail_alpha": {
          "anyOf": [
            {
              "exclusiveMaximum": 1.0,
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tail Alpha"
        }
      },
      "title": "RiskConfig",
      "type": "object"
    },
    "SiteSpec": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "poi_export_limit_mw": {
          "exclusiveMinimum": 0.0,
          "title": "Poi Export Limit Mw",
          "type": "number"
        },
        "poi_import_limit_mw": {
          "exclusiveMinimum": 0.0,
          "title": "Poi Import Limit Mw",
          "type": "number"
        }
      },
      "required": [
        "id",
        "poi_import_limit_mw",
        "poi_export_limit_mw"
      ],
      "title": "SiteSpec",
      "type": "object"
    },
    "TimingConfig": {
      "properties": {
        "day_ahead_gate_closure_local": {
          "default": "12:00",
          "title": "Day Ahead Gate Closure Local",
          "type": "string"
        },
        "delivery_end_date": {
          "format": "date",
          "title": "Delivery End Date",
          "type": "string"
        },
        "delivery_start_date": {
          "format": "date",
          "title": "Delivery Start Date",
          "type": "string"
        },
        "execution_lock_intervals": {
          "default": 1,
          "minimum": 1,
          "title": "Execution Lock Intervals",
          "type": "integer"
        },
        "rebalance_cadence_minutes": {
          "default": 15,
          "minimum": 15,
          "title": "Rebalance Cadence Minutes",
          "type": "integer"
        },
        "resolution_minutes": {
          "default": 15,
          "minimum": 15,
          "title": "Resolution Minutes",
          "type": "integer"
        },
        "timezone": {
          "title": "Timezone",
          "type": "string"
        }
      },
      "required": [
        "timezone",
        "delivery_start_date",
        "delivery_end_date"
      ],
      "title": "TimingConfig",
      "type": "object"
    }
  },
  "properties": {
    "afrr": {
      "anyOf": [
        {
          "$ref": "#/$defs/AfrrConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "artifacts": {
      "$ref": "#/$defs/ArtifactConfig"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/AssetSpec"
      },
      "title": "Assets",
      "type": "array"
    },
    "data": {
      "$ref": "#/$defs/DataConfig"
    },
    "degradation": {
      "$ref": "#/$defs/DegradationConfig"
    },
    "fcr": {
      "anyOf": [
        {
          "$ref": "#/$defs/FcrConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "forecast_provider": {
      "$ref": "#/$defs/ForecastProviderConfig"
    },
    "market": {
      "$ref": "#/$defs/MarketConfig"
    },
    "revision": {
      "anyOf": [
        {
          "$ref": "#/$defs/RevisionConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "risk": {
      "$ref": "#/$defs/RiskConfig"
    },
    "run_name": {
      "title": "Run Name",
      "type": "string"
    },
    "schema_version": {
      "const": 4,
      "title": "Schema Version",
      "type": "integer"
    },
    "site": {
      "$ref": "#/$defs/SiteSpec"
    },
    "timing": {
      "$ref": "#/$defs/TimingConfig"
    },
    "workflow": {
      "enum": [
        "da_only",
        "da_plus_imbalance",
        "da_plus_fcr",
        "da_plus_afrr",
        "schedule_revision"
      ],
      "title": "Workflow",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_name",
    "market",
    "workflow",
    "forecast_provider",
    "timing",
    "site",
    "assets",
    "data"
  ],
  "title": "BacktestConfig",
  "type": "object"
}